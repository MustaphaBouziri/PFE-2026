# BC backend
BC_HOST=https://your-bc-server.example.com
BC_INSTANCE=YourBCInstance
BC_COMPANY=YourCompanyGUID

# Proxy
PROXY_PORT=3000
NODE_ENV=development

# Comma-separated list of origins allowed to call this proxy
# In production this is your Flutter app's domain
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000,https://your-flutter-app.com

# Request timeout in ms (BC can be slow)
BC_TIMEOUT_MS=30000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

BC_DOMAIN=CONTOSO
BC_USERNAME=svc-mes-proxy
BC_PASSWORD=YourServiceAccountPassword