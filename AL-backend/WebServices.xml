<?xml version="1.0" encoding="utf-8"?>
<!-- =====================================================================
     File   : WebServices.xml
     Purpose: Publish only the MES Web Service facade as ODataV4.

     All public OData procedures are now exposed through Codeunit 50126
     "MES Web Service". Endpoint format:

       POST <baseUrl>/ODataV4/MESWebService_<ProcedureName>

     Example:
       POST <baseUrl>/ODataV4/MESWebService_Login
===================================================================== -->
<ExposedWebServices>
    <WebService>
        <ServiceName>MESWebService</ServiceName>
        <CodeunitName>MES Web Service</CodeunitName>
        <ObjectID>50126</ObjectID>
        <Published>true</Published>
    </WebService>
</ExposedWebServices>
