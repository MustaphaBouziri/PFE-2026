# ════════════════════════════════════════════════════════════════════════════
# MES AI Agent — environment configuration
# Copy this file to .env and fill in the values for your chosen provider.
# ════════════════════════════════════════════════════════════════════════════

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one: ollama | openai | huggingface | openai_compatible | anthropic
LLM_PROVIDER=ollama

# Shared LLM settings (applied to whichever provider is active)
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=120


# ── Ollama (local, default) ───────────────────────────────────────────────────
# Used when LLM_PROVIDER=ollama
# Run locally: ollama pull llama3.1:8b && ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b


# ── OpenAI ────────────────────────────────────────────────────────────────────
# Used when LLM_PROVIDER=openai
# Docs: https://platform.openai.com/docs/models
# Models: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo, o1-mini
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini


# ── HuggingFace Serverless Inference API ──────────────────────────────────────
# Used when LLM_PROVIDER=huggingface
# Get a token at: https://huggingface.co/settings/tokens
# Free tier works for small/medium models; PRO token for Llama 3 etc.
# Recommended chat models:
#   meta-llama/Llama-3.1-8B-Instruct     (good quality, PRO required)
#   mistralai/Mistral-7B-Instruct-v0.3   (free tier)
#   microsoft/Phi-3.5-mini-instruct       (free tier, fast)
#   Qwen/Qwen2.5-7B-Instruct              (free tier)
HF_API_KEY=hf_...
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct
# Set to true to use the newer HF router endpoint (higher throughput)
HF_USE_ROUTER=false


# ── OpenAI-compatible endpoint ────────────────────────────────────────────────
# Used when LLM_PROVIDER=openai_compatible
# Works with any server that speaks the OpenAI /v1/chat/completions spec.
#
# Provider          BASE_URL                                  Example model
# ──────────────────────────────────────────────────────────────────────────
# Groq              https://api.groq.com/openai/v1            llama-3.1-8b-instant
# Together.ai       https://api.together.xyz/v1               meta-llama/Llama-3.1-8B
# Mistral AI        https://api.mistral.ai/v1                 mistral-small-latest
# Fireworks.ai      https://api.fireworks.ai/inference/v1     accounts/fireworks/models/llama-v3-8b-instruct
# Anyscale          https://api.endpoints.anyscale.com/v1     meta-llama/Llama-3-8b-chat-hf
# vLLM (local)      http://localhost:8000/v1                  (whatever model you loaded)
# LM Studio         http://localhost:1234/v1                  (whatever model you loaded)
OPENAI_COMPATIBLE_BASE_URL=https://api.groq.com/openai/v1
OPENAI_COMPATIBLE_API_KEY=gsk_...
OPENAI_COMPATIBLE_MODEL=llama-3.1-8b-instant


# ── Anthropic ─────────────────────────────────────────────────────────────────
# Used when LLM_PROVIDER=anthropic
# Docs: https://docs.anthropic.com/en/docs/about-claude/models
# Models: claude-3-5-haiku-20241022 (fast+cheap), claude-3-5-sonnet-20241022 (best)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-haiku-20241022


# ── Node middleware ───────────────────────────────────────────────────────────
MIDDLEWARE_BASE_URL=http://localhost:3000/api
BC_COMPANY=your-company-guid-here
TOOL_HTTP_TIMEOUT=20

# ── Agent behaviour ───────────────────────────────────────────────────────────
LLM_MAX_CONTEXT_CHARS=12000
# Set to true to include tool names in the API response (for debugging)
DEBUG_DATA=false
