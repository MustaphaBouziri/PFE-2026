# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TEMPERATURE=0.1

# Node middleware (the existing Node proxy)
MIDDLEWARE_BASE_URL=http://localhost:3000/api

# BC company GUID (same as BC_COMPANY in your .env)
BC_COMPANY=your-company-guid-here

# Tool HTTP timeout (seconds)
TOOL_HTTP_TIMEOUT=20

# Max LLM ↔ tool rounds before forcing final answer
MAX_TOOL_ROUNDS=4

# Set to true to include raw fetched data in API response (for debugging)
DEBUG_DATA=false
